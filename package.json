{
  "name": "claude-progress-dashboard",
  "displayName": "Claude Progress Dashboard",
  "description": "Aggregated, real-time dashboard of your Claude Code sessions — status, activity, and history across all sessions, including Remote SSH.",
  "version": "0.1.0",
  "publisher": "your-publisher-id",
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "claude",
    "claude code",
    "ai",
    "dashboard",
    "agent",
    "sessions"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/claude-progress-dashboard.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/claude-progress-dashboard/issues"
  },
  "homepage": "https://github.com/your-org/claude-progress-dashboard#readme",
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeDashboard",
          "title": "Claude Dashboard",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "claudeDashboard": [
        {
          "id": "claudeDashboard.sessions",
          "name": "Sessions",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeDashboard.show",
        "title": "Claude Dashboard: Show Sessions",
        "category": "Claude Dashboard"
      },
      {
        "command": "claudeDashboard.installHooks",
        "title": "Claude Dashboard: Install Hooks",
        "category": "Claude Dashboard"
      },
      {
        "command": "claudeDashboard.refresh",
        "title": "Claude Dashboard: Refresh",
        "category": "Claude Dashboard",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeDashboard.clearCompleted",
        "title": "Claude Dashboard: Clear Completed Sessions",
        "category": "Claude Dashboard"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeDashboard.refresh",
          "when": "view == claudeDashboard.sessions",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Claude Progress Dashboard",
      "properties": {
        "claudeDashboard.eventsDirectory": {
          "type": "string",
          "default": "",
          "description": "Directory containing per-session JSONL event logs. Leave empty to use the default (~/.claude/dashboard/events)."
        },
        "claudeDashboard.idleThresholdSeconds": {
          "type": "number",
          "default": 60,
          "description": "Seconds of inactivity after which an active session is shown as idle."
        },
        "claudeDashboard.historyLimit": {
          "type": "number",
          "default": 100,
          "description": "Maximum number of in-memory activity entries kept per session for the UI."
        },
        "claudeDashboard.retentionDays": {
          "type": "number",
          "default": 7,
          "description": "Delete event log files older than this many days on startup. Set to 0 to disable pruning."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
